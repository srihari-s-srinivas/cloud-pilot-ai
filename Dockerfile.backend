# Backend Dockerfile
FROM node:20-slim

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy all files
COPY . .

# Expose backend port
EXPOSE 3000

# Start the server using tsx in dev or compiled in prod
# For this setup, we'll use tsx to support the user's local dev request
CMD ["npm", "run", "dev"]
